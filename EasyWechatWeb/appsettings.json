{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "IsUseSwagger": true,
  "MasterSlaveConnectionStrings": [
    {
      "ConnectionString": "Server=127.0.0.1;Database=EasyProject;User ID=root;Password=your_password;Charset=utf8mb4;",
      "DbType": 0,
      "IsAutoCloseConnection": true,
      "InitKeyType": 1
    }
  ],
  "JWTTokenOptions": {
    "Audience": "http://localhost:51062",
    "Issuer": "http://localhost:5106",
    "SecurityKey": "your-256-bit-secret-key-here-min-16-chars"
  },
  "Redis": {
    "Host": "127.0.0.1",
    "Port": 6379,
    "Password": "",
    "preName": "EasyProject:"
  },
  "Serilog": {
    "LogPath": "logs",
    "LogLevel": "Information",
    "EnableRequestLogging": true
  }
}
